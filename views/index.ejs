<%- include('partials/header') %>

<div class="app">
  <aside class="sidebar">
    <div class="sidebar-head">
      <div class="d-flex gap-2 mb-2">
        <button id="new-note" class="btn btn-primary btn-sm flex-grow-1" type="button">
          New note
        </button>
        <button
          id="export-all"
          class="btn btn-outline-secondary btn-sm"
          type="button"
          title="Download every note as a .zip of .md files">
          Export
        </button>
      </div>
      <input
        id="search"
        class="form-control form-control-sm"
        type="search"
        placeholder="Search notes"
        autocomplete="off">
    </div>
    <ul id="note-list" class="note-list"></ul>
    <p id="empty-list" class="empty-list d-none">No notes yet.</p>
  </aside>

  <main class="editor">
    <div id="editor-pane" class="editor-pane d-none">
      <div class="editor-bar">
        <span id="status" class="status"></span>
        <div class="btn-group btn-group-sm">
          <button id="toggle-preview" class="btn btn-outline-secondary" type="button">
            Preview
          </button>
          <button id="download-note" class="btn btn-outline-secondary" type="button">
            Download
          </button>
          <button id="pin-note" class="btn btn-outline-secondary" type="button">Pin</button>
          <button id="delete-note" class="btn btn-outline-danger" type="button">Delete</button>
        </div>
      </div>
      <textarea
        id="note-body"
        class="note-body"
        placeholder="Start typing. The first line becomes the title. Markdown works."
        spellcheck="true"></textarea>
      <div id="note-preview" class="note-preview d-none"></div>
    </div>

    <div id="editor-empty" class="editor-empty">
      <p class="text-secondary mb-2">Select a note, or start a new one.</p>
      <p class="text-secondary small mb-0">
        <kbd>Ctrl</kbd> + <kbd>N</kbd> new &middot;
        <kbd>Ctrl</kbd> + <kbd>K</kbd> search &middot;
        <kbd>Ctrl</kbd> + <kbd>E</kbd> preview
      </p>
    </div>
  </main>
</div>

<script type="module" src="/js/app.js"></script>
</body>
</html>
