<!doctype html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <script>
    // Set the theme before any CSS applies so there is no flash of the wrong
    // one. Saved choice wins; otherwise follow the OS, defaulting to dark.
    (function () {
      try {
        var saved = localStorage.getItem('notes:theme');
        var theme =
          saved ||
          (window.matchMedia('(prefers-color-scheme: light)').matches
            ? 'light'
            : 'dark');
        document.documentElement.setAttribute('data-bs-theme', theme);
      } catch (e) {
        /* private mode / no storage -- keep the default on <html> */
      }
    })();
  </script>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
